    <!-- SKRIPTY -->
    <script>
      // ── Viewport výška — fix pro Firefox a mobilní prohlížeče ──────────────
      // Uložíme výšku při loadu. Aktualizujeme JEN při změně šířky (ne při scrollu
      // kdy Firefox/Chrome skrývají/ukazují adresní lištu a měnili by výšku stránky).
      let lastWidth = window.innerWidth;

      function setVh(): void {
        document.documentElement.style.setProperty('--real-vh', `${window.innerHeight}px`);
      }

      // Nastavíme hned — před prvním renderem pokud možno
      setVh();
      // A ještě jednou po loadu (fonty, obrázky mohly změnit layout)
      window.addEventListener('load', setVh);

      window.addEventListener('resize', () => {
        const currentWidth = window.innerWidth;
        // Aktualizujeme výšku POUZE pokud se změnila šířka okna.
        // Čistá změna výšky = scroll lišta prohlížeče = ignorujeme.
        if (currentWidth !== lastWidth) {
          lastWidth = currentWidth;
          setVh();
        }
      });

      // ── Header výška pro scroll-margin-top a mobilní menu ──────────────────
      // Header má pevnou výšku v CSS (--header-h: 72px), tady ji jen potvrdíme
      // pro případ že by se změnila (např. při velmi malém displeji).
      // Nezapisujeme zpět do #site-header — jen do CSS proměnné pro ostatní.
      function syncHeaderVar(): void {
        const h = document.getElementById('site-header');
        if (h) {
          document.documentElement.style.setProperty('--header-h', `${h.offsetHeight}px`);
        }
      }
      window.addEventListener('load', syncHeaderVar);
      window.addEventListener('resize', () => {
        if (window.innerWidth !== lastWidth) syncHeaderVar();
      });

      // ── Mobilní menu ────────────────────────────────────────────────────────
      const burgerBtn  = document.getElementById('burger-btn')  as HTMLButtonElement | null;
      const mobileMenu = document.getElementById('mobile-menu') as HTMLDivElement   | null;

      function toggleMenu(): void {
        if (!burgerBtn || !mobileMenu) return;
        const isOpen = mobileMenu.classList.contains('open');
        mobileMenu.classList.toggle('open', !isOpen);
        burgerBtn.classList.toggle('open', !isOpen);
        burgerBtn.setAttribute('aria-expanded', String(!isOpen));
        document.body.style.overflow = isOpen ? '' : 'hidden';
      }

      burgerBtn?.addEventListener('click', toggleMenu);
      document.querySelectorAll<HTMLAnchorElement>('.m-link').forEach(l =>
        l.addEventListener('click', () => { if (mobileMenu?.classList.contains('open')) toggleMenu(); })
      );
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 860 && mobileMenu?.classList.contains('open')) toggleMenu();
      });

      // ── Scroll reveal ────────────────────────────────────────────────────────
      const ro = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); ro.unobserve(e.target); }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll<HTMLElement>('.reveal').forEach(el => ro.observe(el));

      // ── Formulář ─────────────────────────────────────────────────────────────
      (function (): void {
        const formEl     = document.getElementById('contact-form')     as HTMLFormElement   | null;
        const questionEl = document.getElementById('captcha-question') as HTMLElement       | null;
        const answerEl   = document.getElementById('captcha-answer')   as HTMLInputElement  | null;
        const captchaErr = document.getElementById('captcha-error')    as HTMLElement       | null;
        const successEl  = document.getElementById('form-success')     as HTMLElement       | null;
        const resetBtn   = document.getElementById('form-reset-btn')   as HTMLButtonElement | null;
        if (!formEl || !questionEl || !answerEl) return;

        let correct = 0;
        function genCaptcha(): void {
          const a = Math.floor(Math.random() * 6) + 1;
          const b = Math.floor(Math.random() * 4) + 1;
          correct = a + b;
          questionEl!.textContent = `${a} + ${b} = ?`;
          answerEl!.value = '';
          if (captchaErr) { captchaErr.textContent = ''; captchaErr.classList.remove('show'); }
        }
        genCaptcha();

        type Rule = { input: HTMLInputElement | HTMLTextAreaElement; err: HTMLElement; validate: (v: string) => string | null; };
        const rules: Rule[] = ([
          { input: document.getElementById('name')    as HTMLInputElement,    err: document.getElementById('name-error')!,    validate: (v: string) => v.trim().length < 2 ? 'Zadejte jméno a příjmení.' : null },
          { input: document.getElementById('email')   as HTMLInputElement,    err: document.getElementById('email-error')!,   validate: (v: string) => !v.trim() ? 'E-mail je povinný.' : !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? 'Neplatná e-mailová adresa.' : null },
          { input: document.getElementById('message') as HTMLTextAreaElement, err: document.getElementById('message-error')!, validate: (v: string) => v.trim().length < 5 ? 'Zpráva nesmí být prázdná.' : null },
        ] as Rule[]).filter(r => r.input && r.err);

        function validateField(r: Rule): boolean {
          const msg = r.validate(r.input.value);
          if (msg) {
            r.err.textContent = msg; r.err.classList.add('show');
            r.input.classList.add('invalid'); r.input.classList.remove('valid');
            return false;
          }
          r.err.textContent = ''; r.err.classList.remove('show');
          r.input.classList.remove('invalid');
          if (r.input.value.trim()) r.input.classList.add('valid');
          return true;
        }
        rules.forEach(r => {
          r.input.addEventListener('blur',  () => validateField(r));
          r.input.addEventListener('input', () => { if (r.input.classList.contains('invalid')) validateField(r); });
        });

        formEl.addEventListener('submit', (e: Event) => {
          e.preventDefault();
          const allValid   = rules.map(validateField).every(Boolean);
          const captchaVal = parseInt(answerEl!.value, 10);
          const captchaOk  = !isNaN(captchaVal) && captchaVal === correct;
          if (!captchaOk && captchaErr) {
            captchaErr.textContent = 'Špatný výsledek. Zkuste znovu.';
            captchaErr.classList.add('show');
            genCaptcha(); answerEl?.focus();
          }
          if (!allValid || !captchaOk) { (formEl.querySelector<HTMLElement>('.invalid'))?.focus(); return; }
          successEl?.classList.add('show');
        });

        resetBtn?.addEventListener('click', () => {
          formEl.reset();
          rules.forEach(r => { r.input.classList.remove('valid','invalid'); r.err.textContent = ''; r.err.classList.remove('show'); });
          genCaptcha(); successEl?.classList.remove('show');
        });
      })();
    </script>

